# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/whalealert

# ─────────────────────────────────────────────────────────────────
# Etherscan API V2 — ONE key covers all EVM chains:
#   ETH (chainid=1), BSC (chainid=56), Polygon (chainid=137) + 60 more
# Get your free key at: https://etherscan.io/apis
# Free tier: 5 calls/second, 100,000 calls/day
# ─────────────────────────────────────────────────────────────────
ETHERSCAN_API_KEY=your_etherscan_api_key

# TronGrid — optional, increases TRX rate limit
# Get at: https://www.trongrid.io/  (leave blank to use public endpoint)
TRONGRID_API_KEY=

# CoinGecko — leave blank for free public API (10-30 req/min)
# Get Pro key at: https://www.coingecko.com/en/api  for higher limits
COINGECKO_API_KEY=

# App settings
LOG_LEVEL=INFO
PORT=8000
APP_ENV=production  # development | production

# Whale USD thresholds (optional — these are the defaults)
WHALE_THRESHOLD_ETH=500000
WHALE_THRESHOLD_BTC=500000
WHALE_THRESHOLD_BSC=200000
WHALE_THRESHOLD_SOL=200000
WHALE_THRESHOLD_TRX=100000
WHALE_THRESHOLD_MATIC=100000

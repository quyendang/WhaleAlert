# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/whalealert

# Blockchain API Keys (free tiers available at respective websites)
ETHERSCAN_API_KEY=your_etherscan_api_key
BSCSCAN_API_KEY=your_bscscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key
TRONGRID_API_KEY=your_trongrid_api_key  # optional, increases rate limit

# CoinGecko (leave blank for free public API, add key for Pro)
COINGECKO_API_KEY=

# App settings
LOG_LEVEL=INFO
PORT=8000
APP_ENV=production  # development | production

# Whale USD thresholds (optional overrides)
WHALE_THRESHOLD_ETH=500000
WHALE_THRESHOLD_BTC=500000
WHALE_THRESHOLD_BSC=200000
WHALE_THRESHOLD_SOL=200000
WHALE_THRESHOLD_TRX=100000
WHALE_THRESHOLD_MATIC=100000
